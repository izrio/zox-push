# 企业微信企业 ID，格式通常类似 wwxxxxxxxxxxxxxxxx
WECOM_CID=

# 企业微信应用 AgentId，必须是纯数字
WECOM_AID=

# 企业微信应用 Secret
WECOM_SECRET=

# 默认接收人。
# 可填 @all、单个成员账号，或多个成员账号用 | 分隔。
DEFAULT_TOUSER=@all

# 服务监听端口。
# 当前项目默认使用较偏门的 38127，避免与常见业务端口冲突。
PORT=38127

# 容器内数据目录。
# 用于保存自动生成的 send key，通常不需要改。
DATA_DIR=/data

# 企业微信请求超时时间，单位秒。
REQUEST_TIMEOUT=10

# 可选：公网访问前缀。
# 配置后，服务启动日志会打印完整发送地址。
# 例如 http://your-domain.com:38127
PUBLIC_BASE_URL=
