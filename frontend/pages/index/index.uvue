  border-width: 1px;
  border-style: solid;
  border-color: #d96c6c;
}

.list-wrap {
  margin-top: 4px;
}

.message-card {
  margin-bottom: 14px;
  padding: 18px;
  border-radius: 18px;
  background-color: #ffffff;
}

.message-top {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.message-title {
  flex: 1;
  font-size: 18px;
  font-weight: 700;
  color: #14213d;
}

.message-type {
  margin-left: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  background-color: #d7ecff;
  font-size: 12px;
  color: #1b4965;
}

.message-preview {
  margin-top: 12px;
  font-size: 14px;
  line-height: 22px;
  color: #49627a;
}

