  margin-top: 14px;
  border-radius: 999px;
  background-color: #f7b267;
  color: #13293d;
}

.panel {
  padding: 18px;
  border-radius: 16px;
  background-color: #ffffff;
}

.panel-title {
  font-size: 18px;
  font-weight: 700;
  color: #13293d;
}

.panel-body {
  margin-top: 8px;
  font-size: 14px;
  line-height: 20px;
  color: #49627a;
}

